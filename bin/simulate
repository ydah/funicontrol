#!/usr/bin/env ruby

require_relative "../config/environment"

STDOUT.sync = true

trap("INT") { puts "\nStopping simulation"; exit }
trap("TERM") { puts "\nStopping simulation"; exit }

puts "Starting Funicontrol simulation..."

tick = 0
tick_interval = ENV.fetch("SIM_TICK_INTERVAL", "1").to_f
random_events_enabled = ENV["SIM_RANDOM_EVENTS"] == "1"
if ENV["SIM_ACTIVE_JOB"] == "1"
  SimulationTickJob.perform_later(
    continue: true,
    interval: tick_interval,
    random_events: random_events_enabled
  )
  puts "Enqueued SimulationTickJob with #{tick_interval}s interval"
  exit
end

loop do
  Rails.application.executor.wrap do
    ActiveRecord::Base.connection.clear_query_cache
    Line.find_each do |line|
      AdvanceCarPositions.call(line:)
      RandomSimulationEvents.call(line:) if random_events_enabled
    end
  end
  tick += 1
  if tick == 1 || (tick % 5).zero?
    summary = Car.order(:code).map { |car| "#{car.code}=#{car.position.to_f.round(3)} #{car.direction} #{car.status}" }.join(" | ")
    puts "Simulation tick #{tick}: #{summary}"
  end
  sleep tick_interval
end
